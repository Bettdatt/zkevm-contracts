{
  "name": "@imtbl/contracts",
  "version": "3.1.1",
  "description": "Immutable Smart Contracts",
  "author": "Immutable",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/immutable/contracts.git"
  },
  "homepage": "https://github.com/immutable/contracts",
  "bugs": {
    "url": "https://github.com/immutable/contracts/issues"
  },
  "type": "module",
  "files": [
    "dist",
    "contracts/**/*.sol",
    "!contracts/mocks/**"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./abis": {
      "types": "./dist/abis.d.ts",
      "import": "./dist/abis.js",
      "default": "./dist/abis.js"
    },
    "./addresses": {
      "types": "./dist/addresses.d.ts",
      "import": "./dist/addresses.js",
      "default": "./dist/addresses.js"
    },
    "./contracts/*": "./contracts/*"
  },
  "scripts": {
    "build": "tsc",
    "compile": "forge build",
    "test": "forge test",
    "test:coverage": "forge coverage",
    "format": "forge fmt",
    "format:check": "forge fmt --check",
    "lint": "solhint 'contracts/**/*.sol'",
    "clean": "node -e \"const fs=require('fs');['dist','foundry-out','cache','artifacts','broadcast'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@openzeppelin/contracts": "^4.9.3 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "blockchain",
    "contracts",
    "ethereum",
    "immutable",
    "solidity"
  ]
}
